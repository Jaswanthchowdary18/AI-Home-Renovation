# ARKEN — Environment Variables v3.0
# Copy to .env and fill in real values

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=ARKEN PropTech Engine
ENVIRONMENT=development
DEBUG=true

# ── Security (generate: openssl rand -hex 32) ─────────────────────────────────
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars

# ── Database — optional in dev (system starts without PostgreSQL) ─────────────
DATABASE_URL=postgresql+asyncpg://arken:arken@localhost:5432/arken

# ── Redis — optional in dev (system falls back to in-memory cache) ────────────
REDIS_URL=redis://localhost:6379/0

# ── AWS S3 — optional (set USE_S3=true to persist renders and masks) ──────────
USE_S3=false
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=ap-south-1
S3_BUCKET_UPLOADS=arken-uploads-dev
S3_BUCKET_RENDERS=arken-renders-dev
S3_BUCKET_ARTIFACTS=arken-artifacts-dev
CDN_BASE_URL=https://cdn.yourdomain.in

# ── AI API (REQUIRED for full functionality) ──────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
# Used for: Gemini Vision (room analysis), Gemini Chat, Image Generation
GOOGLE_API_KEY=AIzaSyBNKExIcDRRsZ0WUgxBVoRBbvegeMs2IHM

# ── ML Model Paths — auto-created on first run ────────────────────────────────
XGBOOST_MODEL_PATH=ml/weights/roi_xgb.joblib

# ── Vector Store — ChromaDB (local, no extra config needed) ───────────────────
CHROMA_PERSIST_DIR=/tmp/arken_chroma
# Optional Pinecone cloud store:
# PINECONE_API_KEY=your-pinecone-key
# PINECONE_INDEX=arken-insights

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
