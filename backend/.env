# ARKEN — Environment Variables
# Copy to .env and fill in real values

# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=ARKEN PropTech Engine
ENVIRONMENT=development
DEBUG=true

# ── Security (generate with: openssl rand -hex 32) ───────────────────────────
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://arken:arken@localhost:5432/arken

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── AWS S3 (Mumbai region) ───────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=ap-south-1
S3_BUCKET_UPLOADS=arken-uploads-dev
S3_BUCKET_RENDERS=arken-renders-dev
S3_BUCKET_ARTIFACTS=arken-artifacts-dev
CDN_BASE_URL=https://cdn.yourdomain.in

# ── AI APIs (at least one render provider required) ──────────────────────────
GOOGLE_API_KEY=AIzaSyBNKExIcDRRsZ0WUgxBVoRBbvegeMs2IHM
OPENAI_API_KEY=your-openai-api-key
STABILITY_API_KEY=your-stability-ai-key

# ── ML Model Paths ────────────────────────────────────────────────────────────
YOLO_MODEL_PATH=ml/weights/yolov8x-seg.pt
XGBOOST_MODEL_PATH=ml/weights/roi_xgb.json
PROPHET_MODEL_DIR=ml/weights/prophet/
CLIP_MODEL=ViT-L/14
